@model BlogicCRM.Models.Client

@{
    ViewData["Title"] = "Detail klienta";
}

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Detail klienta</h5>
    </div>
    <div class="card-body">
        <h6>Osobní údaje</h6>
        <dl class="row">
            <dt class="col-sm-3">Jméno</dt>
            <dd class="col-sm-9">@Model.FirstName</dd>

            <dt class="col-sm-3">Příjmení</dt>
            <dd class="col-sm-9">@Model.LastName</dd>

            <dt class="col-sm-3">E-mail</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Telefon</dt>
            <dd class="col-sm-9">@Model.Phone</dd>

            <dt class="col-sm-3">Rodné číslo</dt>
            <dd class="col-sm-9">@Model.BirthNumber</dd>

            <dt class="col-sm-3">Věk</dt>
            <dd class="col-sm-9">@Model.Age</dd>
        </dl>

        <h6>Smlouvy klienta</h6>
        @if (Model.Contracts == null || !Model.Contracts.Any())
        {
            <p>Klient zatím nemá žádné smlouvy.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Evidenční číslo</th>
                            <th>Instituce</th>
                            <th>Správce</th>
                            <th>Datum platnosti</th>
                            <th>Akce</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var c in Model.Contracts)
                    {
                        <tr>
                            <td>@c.RegistrationNumber</td>
                            <td>@c.Institution</td>
                            <td>@c.ManagerAdvisor?.FirstName @c.ManagerAdvisor?.LastName</td>
                            <td>@(c.DateValidFrom.ToShortDateString())</td>
                            <td><a class="btn btn-sm btn-outline-primary" asp-controller="Contracts" asp-action="Details" asp-route-id="@c.Id">Detail smlouvy</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="card-footer text-end">
        <a asp-action="Index" class="btn btn-secondary">Zpět na seznam klientů</a>
    </div>
</div>
