@model IEnumerable<BlogicCRM.Models.Client>

@{
    ViewData["Title"] = "Seznam klientů";
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Seznam klientů</h5>
        <div>
            <a class="btn btn-primary me-2" asp-action="Create">Přidat klienta</a>
            <form method="get" asp-action="ExportCsv" asp-controller="Clients" class="d-inline">
                <input type="hidden" name="firstName" value="@ViewData["firstName"]" />
                <input type="hidden" name="lastName" value="@ViewData["lastName"]" />
                <input type="hidden" name="email" value="@ViewData["email"]" />
                <input type="hidden" name="phone" value="@ViewData["phone"]" />
                <input type="hidden" name="birthNumber" value="@ViewData["birthNumber"]" />
                <input type="hidden" name="age" value="@ViewData["age"]" />
                <button type="submit" class="btn btn-outline-primary">Export CSV</button>
            </form>
            <div class="small text-muted mt-1">Export CSV stáhne aktuálně vyfiltrované záznamy.</div>
        </div>
    </div>
    <div class="card-body">
        <div class="card mb-3">
            <div class="card-body">
                <form method="get">
                    <div class="row g-2">
                        <div class="col-md-3">
                            <input type="text" name="firstName" value="@Context.Request.Query["firstName"]" class="form-control" placeholder="Jméno" />
                        </div>
                        <div class="col-md-3">
                            <input type="text" name="lastName" value="@Context.Request.Query["lastName"]" class="form-control" placeholder="Příjmení" />
                        </div>
                        <div class="col-md-3">
                            <input type="text" name="email" value="@Context.Request.Query["email"]" class="form-control" placeholder="E-mail" />
                        </div>
                        <div class="col-md-3">
                            <input type="text" name="phone" value="@Context.Request.Query["phone"]" class="form-control" placeholder="Telefon" />
                        </div>
                        <div class="col-md-3 mt-2">
                            <input type="text" name="birthNumber" value="@Context.Request.Query["birthNumber"]" class="form-control" placeholder="Rodné číslo" />
                        </div>
                        <div class="col-md-3 mt-2">
                            <input type="number" name="age" value="@Context.Request.Query["age"]" class="form-control" placeholder="Věk" />
                        </div>
                        <div class="col-md-6 d-flex align-items-center mt-2">
                            <button class="btn btn-outline-secondary me-2" type="submit">Filtrovat</button>
                            <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Clients")">Zrušit filtr</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @if (!Model.Any())
        {
            <p>Nebyly nalezeny žádné záznamy odpovídající filtru.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Jméno</th>
                            <th>Příjmení</th>
                            <th>E-mail</th>
                            <th>Telefon</th>
                            <th>Rodné číslo</th>
                            <th>Věk</th>
                            <th>Akce</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.FirstName</td>
                            <td>@item.LastName</td>
                            <td>@item.Email</td>
                            <td>@item.Phone</td>
                            <td>@item.BirthNumber</td>
                            <td>@item.Age</td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary btn-detail" asp-action="Details" asp-route-id="@item.Id">Detail</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
