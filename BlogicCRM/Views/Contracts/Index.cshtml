@model IEnumerable<BlogicCRM.Models.Contract>

@{
    ViewData["Title"] = "Seznam smluv";
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Seznam smluv</h5>
        <a class="btn btn-primary" asp-action="Create">Přidat smlouvu</a>
    </div>
    <div class="card-body">
        <div class="card mb-3">
            <div class="card-body">
                <form method="get">
                    <div class="row g-2">
                        <div class="col-md-3">
                            <input type="text" name="registrationNumber" value="@Context.Request.Query["registrationNumber"]" class="form-control" placeholder="Evidenční číslo" />
                        </div>
                        <div class="col-md-3">
                            <input type="text" name="institution" value="@Context.Request.Query["institution"]" class="form-control" placeholder="Instituce" />
                        </div>
                        <div class="col-md-3">
                            <input type="text" name="clientFirstName" value="@Context.Request.Query["clientFirstName"]" class="form-control" placeholder="Jméno klienta" />
                        </div>
                        <div class="col-md-3">
                            <input type="text" name="clientLastName" value="@Context.Request.Query["clientLastName"]" class="form-control" placeholder="Příjmení klienta" />
                        </div>
                        <div class="col-md-3 mt-2">
                            <input type="text" name="managerFirstName" value="@Context.Request.Query["managerFirstName"]" class="form-control" placeholder="Jméno správce" />
                        </div>
                        <div class="col-md-3 mt-2">
                            <input type="text" name="managerLastName" value="@Context.Request.Query["managerLastName"]" class="form-control" placeholder="Příjmení správce" />
                        </div>
                        <div class="col-md-3 mt-2">
                            @{
                                var status = Context.Request.Query["statusFilter"].ToString();
                                var statusItems = new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
                                {
                                    new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Value = "All", Text = "Všechny", Selected = string.IsNullOrEmpty(status) || status == "All" },
                                    new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Value = "Active", Text = "Aktivní", Selected = status == "Active" },
                                    new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Value = "Ended", Text = "Ukončené", Selected = status == "Ended" }
                                };
                            }
                            <select name="statusFilter" class="form-select" asp-items="statusItems"></select>
                        </div>
                        <div class="col-md-3 d-flex align-items-center mt-2">
                            <button class="btn btn-outline-secondary me-2" type="submit">Filtrovat</button>
                            <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Contracts")">Zrušit filtr</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        @if (!Model.Any())
        {
            <p>Nebyly nalezeny žádné záznamy odpovídající filtru.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Evidenční číslo</th>
                            <th>Instituce</th>
                            <th>Klient</th>
                            <th>Správce smlouvy</th>
                            <th>Datum platnosti</th>
                            <th>Datum ukončení</th>
                            <th>Stav</th>
                            <th>Akce</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.RegistrationNumber</td>
                            <td>@item.Institution</td>
                            <td>@item.Client?.FirstName @item.Client?.LastName</td>
                            <td>@item.ManagerAdvisor?.FirstName @item.ManagerAdvisor?.LastName</td>
                            <td>@item.DateValidFrom.ToShortDateString()</td>
                            <td>@(item.DateEnded.HasValue ? item.DateEnded.Value.ToShortDateString() : "-")</td>
                            <td>
                                @if (!item.DateEnded.HasValue || item.DateEnded.Value > DateTime.Today)
                                {
                                    <span class="badge bg-success">Aktivní</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ukončená</span>
                                }
                            </td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">Detail</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
