@model IEnumerable<BlogicCRM.Models.Contract>

@{
    ViewData["Title"] = "Seznam smluv";
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Seznam smluv</h5>
        <a class="btn btn-primary" asp-action="Create">Přidat smlouvu</a>
    </div>
    <div class="card-body">
        <form method="get" class="mb-3">
            @{
                var status = Context.Request.Query["statusFilter"].ToString();
                var selAll = string.IsNullOrEmpty(status) || status == "All";
                var selActive = status == "Active";
                var selEnded = status == "Ended";
            }
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="input-group">
                        <input type="text" name="searchString" value="@Context.Request.Query["searchString"]" class="form-control" placeholder="Hledat podle evidenčního čísla, instituce, klienta nebo správce" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="statusFilter" class="form-select">
                        <option value="All" selected="@(selAll ? "selected" : null)">Všechny</option>
                        <option value="Active" selected="@(selActive ? "selected" : null)">Aktivní</option>
                        <option value="Ended" selected="@(selEnded ? "selected" : null)">Ukončené</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex">
                    <button class="btn btn-outline-secondary me-2" type="submit">Hledat</button>
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Contracts")">Zrušit filtr</a>
                </div>
            </div>
        </form>

        @if (!Model.Any())
        {
            <p>Nebyly nalezeny žádné záznamy odpovídající filtru.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Evidenční číslo</th>
                            <th>Instituce</th>
                            <th>Klient</th>
                            <th>Správce smlouvy</th>
                            <th>Datum platnosti</th>
                            <th>Datum ukončení</th>
                            <th>Stav</th>
                            <th>Akce</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.RegistrationNumber</td>
                            <td>@item.Institution</td>
                            <td>@item.Client?.FirstName @item.Client?.LastName</td>
                            <td>@item.ManagerAdvisor?.FirstName @item.ManagerAdvisor?.LastName</td>
                            <td>@item.DateValidFrom.ToShortDateString()</td>
                            <td>@(item.DateEnded.HasValue ? item.DateEnded.Value.ToShortDateString() : "-")</td>
                            <td>
                                @if (!item.DateEnded.HasValue || item.DateEnded.Value >= DateTime.Today)
                                {
                                    <span class="badge bg-success">Aktivní</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ukončená</span>
                                }
                            </td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary me-1" asp-action="Details" asp-route-id="@item.Id">Detail</a>
                                <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Edit" asp-route-id="@item.Id">Upravit</a>
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Smazat</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
