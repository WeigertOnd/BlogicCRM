@model BlogicCRM.Models.Contract

@{
    ViewData["Title"] = "Detail smlouvy";
}

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Detail smlouvy</h5>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Evidenční číslo</dt>
            <dd class="col-sm-9">@Model.RegistrationNumber</dd>

            <dt class="col-sm-3">Instituce</dt>
            <dd class="col-sm-9">@Model.Institution</dd>

            <dt class="col-sm-3">Klient</dt>
            <dd class="col-sm-9"><a asp-controller="Clients" asp-action="Details" asp-route-id="@Model.ClientId">@Model.Client?.FirstName @Model.Client?.LastName</a></dd>

            <dt class="col-sm-3">Správce smlouvy</dt>
            <dd class="col-sm-9"><a asp-controller="Advisors" asp-action="Details" asp-route-id="@Model.ManagerAdvisorId">@Model.ManagerAdvisor?.FirstName @Model.ManagerAdvisor?.LastName</a></dd>

            <dt class="col-sm-3">Datum uzavření</dt>
            <dd class="col-sm-9">@Model.DateClosed.ToShortDateString()</dd>

            <dt class="col-sm-3">Datum platnosti</dt>
            <dd class="col-sm-9">@Model.DateValidFrom.ToShortDateString()</dd>

            <dt class="col-sm-3">Datum ukončení</dt>
            <dd class="col-sm-9">@(Model.DateEnded.HasValue ? Model.DateEnded.Value.ToShortDateString() : "-")</dd>

            <dt class="col-sm-3">Stav</dt>
            <dd class="col-sm-9">
                @if (!Model.DateEnded.HasValue || Model.DateEnded.Value > DateTime.Today)
                {
                    <span class="badge bg-success">Aktivní</span>
                }
                else
                {
                    <span class="badge bg-secondary">Ukončená</span>
                }
            </dd>
        </dl>

        <h6>Účastníci</h6>
        <ul>
        @foreach (var ca in Model.ContractAdvisors ?? new List<BlogicCRM.Models.ContractAdvisor>())
        {
            <li><a asp-controller="Advisors" asp-action="Details" asp-route-id="@ca.AdvisorId">@ca.Advisor?.FirstName @ca.Advisor?.LastName</a></li>
        }
        </ul>
    </div>
    <div class="card-footer text-end">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary me-2">Upravit</a>
        @if (!Model.DateEnded.HasValue || Model.DateEnded.Value >= DateTime.Today)
        {
            <form asp-action="EndContract" method="post" class="d-inline me-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="returnUrl" value="@Url.Action("Details", "Contracts", new { id = Model.Id })" />
                <button type="submit" class="btn btn-outline-warning">Ukončit</button>
            </form>
        }
        else
        {
            <form asp-action="ReactivateContract" method="post" class="d-inline me-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="returnUrl" value="@Url.Action("Details", "Contracts", new { id = Model.Id })" />
                <button type="submit" class="btn btn-outline-success">Obnovit</button>
            </form>
        }
        <a asp-action="Index" class="btn btn-secondary">Zpět na seznam smluv</a>
    </div>
</div>
