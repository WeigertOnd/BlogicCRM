@model BlogicCRM.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Přehled";
}

<div class="py-4 mb-4">
    <div class="container-fluid">
        <div class="card p-4">
            <h1 class="mb-1">BlogicCRM</h1>
            <p class="mb-0 text-muted">Interní systém pro správu klientů, poradců a smluv.</p>
        </div>
    </div>
</div>

<div class="row gy-3 mb-4">
    <div class="col-md-3">
        <div class="card p-3">
            <h6 class="text-muted">Klienti</h6>
            <p class="display-6 mb-0">@Model.ClientsCount</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3">
            <h6 class="text-muted">Poradci</h6>
            <p class="display-6 mb-0">@Model.AdvisorsCount</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3">
            <h6 class="text-muted">Smlouvy celkem</h6>
            <p class="display-6 mb-0">@Model.ContractsCount</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3">
            <h6 class="text-muted">Aktivní smlouvy</h6>
            <p class="display-6 mb-0">@Model.ActiveContractsCount</p>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card p-3">
            <h6 class="text-muted">Ukončené smlouvy</h6>
            <p class="display-6 mb-0">@Model.EndedContractsCount</p>
        </div>
    </div>
</div>

<h3>Poslední smlouvy</h3>
@if (!Model.RecentContracts.Any())
{
    <p>Zatím nejsou evidovány žádné smlouvy.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Evidenční číslo</th>
                <th>Instituce</th>
                <th>Klient</th>
                <th>Správce</th>
                <th>Datum platnosti</th>
                <th>Stav</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var c in Model.RecentContracts)
        {
            <tr>
                <td>@c.RegistrationNumber</td>
                <td>@c.Institution</td>
                <td>@c.Client?.FirstName @c.Client?.LastName</td>
                <td>@c.ManagerAdvisor?.FirstName @c.ManagerAdvisor?.LastName</td>
                <td>@c.DateValidFrom.ToShortDateString()</td>
                <td>
                    @if (!c.DateEnded.HasValue || c.DateEnded.Value > DateTime.Today)
                    {
                        <span class="badge bg-success">Aktivní</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Ukončená</span>
                    }
                </td>
                <td><a class="btn btn-sm btn-outline-primary btn-detail" asp-controller="Contracts" asp-action="Details" asp-route-id="@c.Id">Detail</a></td>
            </tr>
        }
        </tbody>
    </table>
}
