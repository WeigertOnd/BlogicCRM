@{
    ViewData["Title"] = "Export dat";
}

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Export dat</h5>
    </div>
    <div class="card-body">
        <p>Vyberte části aplikace, které chcete exportovat do CSV.</p>
        <form method="post" asp-action="Export">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" value="true" id="clients" name="clients" />
                <label class="form-check-label" for="clients">Klienti</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" value="true" id="advisors" name="advisors" />
                <label class="form-check-label" for="advisors">Poradci</label>
            </div>
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" value="true" id="contracts" name="contracts" />
                <label class="form-check-label" for="contracts">Smlouvy</label>
            </div>
            <div class="text-danger">@Html.ValidationSummary()</div>
            <button type="submit" class="btn btn-primary">Exportovat</button>
        </form>
    </div>
</div>